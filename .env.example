# Weekly report generation uses an OpenAI-compatible chat completions API.
# Copy this file to .env and fill in local values. Never commit real keys.

LLM_API_KEY=replace-with-your-api-key
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# OPENAI_* aliases are also supported:
# OPENAI_API_KEY=replace-with-your-api-key
# OPENAI_BASE_URL=https://api.openai.com/v1
